{
  "GHSA-p7fg-763f-g4gf": {
    "active": true,
    "notes": "Insecure default file permissions in @anthropic-ai/sdk's local-filesystem memory tool. We do not enable that tool — claude-strategy only inspects tool names for logging (packages/core/src/strategies/claude-strategy.js:151), it never configures or invokes the memory_* tool. Re-evaluate when @anthropic-ai/claude-agent-sdk ships with @anthropic-ai/sdk >= 0.92.0 and drop this exception.",
    "expiry": "2026-08-01"
  },
  "GHSA-gv7w-rqvm-qjhr": {
    "active": true,
    "notes": "esbuild: missing binary integrity verification in the Deno module enables RCE via NPM_CONFIG_REGISTRY. Build-time only — esbuild is a dev/bundling dep (via vite/tsup), never shipped or executed in production, and we never use the Deno install path. Re-evaluate when vite/tsup bump esbuild past 0.28.0; drop this exception then.",
    "expiry": "2026-09-01"
  },
  "GHSA-g7r4-m6w7-qqqr": {
    "active": true,
    "notes": "esbuild: arbitrary file read when running the dev server on Windows. Build-time only — we never run the esbuild/vite dev server in CI or prod (bundle step only), and not on Windows. Patched in esbuild > 0.28.0. Re-evaluate on the next vite/tsup bump.",
    "expiry": "2026-09-01"
  },
  "GHSA-fx2h-pf6j-xcff": {
    "active": true,
    "notes": "vite: server.fs.deny bypass on Windows alternate paths. Dev-server only — we ship pre-built static assets and never expose the vite dev server in prod; Windows-specific. Re-evaluate when vite ships the patched release; drop this exception then.",
    "expiry": "2026-09-01"
  },
  "GHSA-v6wh-96g9-6wx3": {
    "active": true,
    "notes": "launch-editor: NTLMv2 hash disclosure via UNC path handling on Windows, reached transitively via vite's dev-server error overlay. Dev-only (never invoked in a prod build) and Windows-specific. Re-evaluate when vite bumps launch-editor; drop this exception then.",
    "expiry": "2026-09-01"
  },
  "GHSA-hmw2-7cc7-3qxx": {
    "active": true,
    "notes": "form-data: CRLF injection via unescaped multipart field names/filenames. Reaches us transitively via @anthropic-ai/sdk's HTTP client; the multipart field names we emit are fixed SDK constants, never user-controlled, so the injection vector is unreachable from our usage. Re-evaluate when @anthropic-ai/sdk bumps form-data past 4.0.5; drop this exception then.",
    "expiry": "2026-09-01"
  },
  "GHSA-vmf3-w455-68vh": {
    "active": true,
    "notes": "node-tar: PAX size override applied to intermediary GNU long-name/long-link headers causes a parser interpretation differential (file smuggling). Reaches us only as a build/install-tooling transitive dep (node-gyp / @anthropic-ai/sdk tooling); we never extract untrusted tarballs at runtime. Re-evaluate when upstream bumps tar; drop this exception then.",
    "expiry": "2026-09-01"
  },
  "GHSA-wwfh-h76j-fc44": {
    "active": true,
    "notes": "hono: path traversal in serve-static on Windows via encoded backslash. Reaches us via @modelcontextprotocol/sdk > hono, used ONLY as a thin stdio/SSE transport for MCP — we never mount hono's serveStatic middleware and our runtime is Linux, not Windows. Vulnerable code path unreachable. Re-evaluate when the MCP SDK bumps to a patched hono.",
    "expiry": "2026-09-01"
  },
  "GHSA-j6c9-x7qj-28xf": {
    "active": true,
    "notes": "hono: AWS Lambda adapter merges multiple Set-Cookie headers. Reaches us via @modelcontextprotocol/sdk > hono used as an MCP stdio/SSE transport — we never run hono through its AWS Lambda adapter and set no cookies on that transport. Unreachable. Re-evaluate when the MCP SDK bumps to a patched hono.",
    "expiry": "2026-09-01"
  },
  "GHSA-88fw-hqm2-52qc": {
    "active": true,
    "notes": "hono: CORS middleware reflects any Origin with credentials when origin defaults to wildcard. Reaches us via @modelcontextprotocol/sdk > hono used as an MCP stdio/SSE transport — we never mount hono's CORS middleware (no browser-origin/credentialed surface). Unreachable. Re-evaluate when the MCP SDK bumps to a patched hono.",
    "expiry": "2026-09-01"
  },
  "GHSA-rv63-4mwf-qqc2": {
    "active": true,
    "notes": "hono: Body Limit middleware bypass on AWS Lambda by understating Content-Length. Reaches us via @modelcontextprotocol/sdk > hono used as an MCP stdio/SSE transport — not on the hono Lambda adapter, no bodyLimit security boundary. Unreachable. Re-evaluate when the MCP SDK bumps to a patched hono.",
    "expiry": "2026-09-01"
  },
  "GHSA-wgpf-jwqj-8h8p": {
    "active": true,
    "notes": "hono: Lambda@Edge adapter keeps only the last value of a repeated request header. Reaches us via @modelcontextprotocol/sdk > hono used as an MCP stdio/SSE transport — we never use hono's Lambda@Edge adapter. Unreachable. Re-evaluate when the MCP SDK bumps to a patched hono.",
    "expiry": "2026-09-01"
  }
}
